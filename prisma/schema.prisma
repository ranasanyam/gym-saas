

// ============================================================
// GYM MANAGEMENT SAAS — Prisma Schema (Final)
// Includes: Core App + SaaS Billing + Referral & Wallet System
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

// ────────────────────────────────────────────────────────────
// ENUMS
// ────────────────────────────────────────────────────────────

enum AuthProvider {
  EMAIL
  GOOGLE
  GITHUB
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ClassStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  BOOKED
  ATTENDED
  CANCELLED
  NO_SHOW
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum NotificationType {
  BILLING
  CLASS_REMINDER
  PLAN_UPDATE
  ANNOUNCEMENT
  REFERRAL
  SYSTEM
}

enum ProfileStatus {
  ACTIVE
  INVITED
}

enum OwnerPlanStatus {
  PENDING_SELECTION
  ACTIVE
}

enum TargetRole {
  OWNER
  TRAINER
  MEMBER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  EXPIRED
}

enum AttendanceMethod {
  MANUAL
  QR
  BIOMETRIC
  SELF
}

// ── SaaS Billing ─────────────────────────────────────────────

enum SaasPlanInterval {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  LIFETIME
}

enum SaasSubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  LIFETIME
}

enum SaasPaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ── Referral & Wallet ────────────────────────────────────────

enum ReferralStatus {
  PENDING    // signed up but hasn't purchased yet
  CONVERTED  // purchased a plan → reward credited
  EXPIRED    // never purchased within the window
}

enum WalletTransactionType {
  CREDIT_REFERRAL     // earned by referring someone
  CREDIT_BONUS        // manual bonus by admin
  DEBIT_SUBSCRIPTION  // used to pay/discount a SaaS plan (platform billing)
  DEBIT_MEMBERSHIP    // used to discount a gym membership fee
  DEBIT_ADJUSTMENT    // manual debit by admin
}

// ────────────────────────────────────────────────────────────
// 1. PROFILES  (all roles share this — owner, trainer, member)
// ────────────────────────────────────────────────────────────

model Profile {
  id           String    @id @default(uuid())
  userId       String    @unique @map("user_id")       // NextAuth user id
  fullName     String    @map("full_name")
  mobileNumber String?       @map("mobile_number")          // NOT @unique in DB — enforced in app code for invites
  email        String?       @unique                       // null for SMS-invited users until they complete profile
  status       ProfileStatus @default(ACTIVE)              // INVITED = owner added by mobile, ACTIVE = completed profile
  gender       String?
  dateOfBirth  DateTime? @map("date_of_birth") @db.Date
  address      String?
  city         String?
  avatarUrl    String?   @map("avatar_url")
  passwordHash String?   @map("password_hash")         // null for OAuth-only users or INVITED users
  role            String?                                    // owner | trainer | member — null until user picks on /select-role
  ownerPlanStatus OwnerPlanStatus? @map("owner_plan_status") // null for non-owners; PENDING_SELECTION until owner picks a plan
  goals           String[]  @default([])
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Core
  oauthAccounts       OAuthAccount[]
  refreshTokens       RefreshToken[]
  ownedGyms           Gym[]               @relation("GymOwner")
  gymTrainer          GymTrainer?
  gymMemberships      GymMember[]
  createdWorkoutPlans WorkoutPlan[]       @relation("WorkoutPlanCreator")
  createdDietPlans    DietPlan[]          @relation("DietPlanCreator")
  announcements       Announcement[]
  notifications       Notification[]
  // SaaS billing
  saasSubscriptions   SaasSubscription[]
  saasPayments        SaasPayment[]
  pushSubscriptions   PushSubscription[]
  planTemplates       PlanTemplate[]
  wallet              Wallet?
  // Referral
  referralCode        ReferralCode?
  referralsMade       Referral[]          @relation("ReferrerProfile")
  expensesAdded       GymExpense[]        @relation("ExpenseAdder")
  referredBy          Referral?           @relation("ReferredProfile")
  inviteTokens        InviteToken[]

  @@map("profiles")
}

// ────────────────────────────────────────────────────────────
// 2. OAUTH ACCOUNTS
// ────────────────────────────────────────────────────────────

model OAuthAccount {
  id             String       @id @default(uuid())
  profileId      String       @map("profile_id")
  provider       AuthProvider
  providerUid    String       @map("provider_uid")
  accessToken    String?      @map("access_token")
  refreshToken   String?      @map("refresh_token")
  tokenExpiresAt DateTime?    @map("token_expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUid])
  @@map("oauth_accounts")
}

// ────────────────────────────────────────────────────────────
// 3. REFRESH TOKENS
// ────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("refresh_tokens")
}

// ────────────────────────────────────────────────────────────
// 4. GYMS
// ────────────────────────────────────────────────────────────

model Gym {
  id            String   @id @default(uuid())
  ownerId       String   @map("owner_id")
  name          String
  address       String?
  city          String?
  state         String?
  pincode       String?
  contactNumber   String?  @map("contact_number")
  whatsappNumber  String?  @map("whatsapp_number")  // owner's WhatsApp for broadcast messages
  services      String[] @default([])
  facilities    String[] @default([])
  gymImages     String[] @default([]) @map("gym_images")
  logoUrl       String?  @map("logo_url")
  timezone      String   @default("Asia/Kolkata")
  currency      String   @default("INR") @db.Char(3)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  owner           Profile          @relation("GymOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  membershipPlans MembershipPlan[]
  trainers        GymTrainer[]
  members         GymMember[]
  attendance      Attendance[]
  payments        Payment[]
  classCategories ClassCategory[]
  classes         Class[]
  workoutPlans     WorkoutPlan[]
  dietPlans        DietPlan[]
  supplements      Supplement[]
  supplementSales  SupplementSale[]
  planTemplates    PlanTemplate[]
  milestones       AttendanceMilestone[]
  announcements   Announcement[]
  notifications   Notification[]
  expenses         GymExpense[]
  lockers          Locker[]
  lockerAssignments LockerAssignment[]

  @@index([ownerId])
  @@map("gyms")
}

// ════════════════════════════════════════════════════════════
// SAAS BILLING  (you → gym owner)
// Completely separate from gym's own member billing
// ════════════════════════════════════════════════════════════

// ────────────────────────────────────────────────────────────
// 5. SAAS PLANS
//
// Suggested tiers (you configure via seed or admin panel):
//
// STARTER   ₹999/mo   — 50 members, 2 trainers, no diet/class
// GROWTH    ₹1999/mo  — 200 members, 5 trainers, diet plans
// PRO       ₹3499/mo  — unlimited, all features, analytics
// LIFETIME  ₹24999    — PRO forever, no recurring charge
//
// null on a limit field = unlimited
// ────────────────────────────────────────────────────────────

model SaasPlan {
  id          String           @id @default(uuid())
  name        String           // "Starter", "Growth", "Pro"
  description String?
  interval    SaasPlanInterval
  price       Decimal          @db.Decimal(10, 2)
  currency    String           @default("INR") @db.Char(3)
  isActive    Boolean          @default(true) @map("is_active")
  sortOrder   Int              @default(0) @map("sort_order") // for display ordering on pricing page

  // ── Usage limits (null = unlimited) ──────────────────────
  maxGyms              Int? @map("max_gyms")
  maxMembers           Int? @map("max_members")
  maxTrainers          Int? @map("max_trainers")
  maxMembershipPlans   Int? @map("max_membership_plans")
  maxNotificationsPerMonth Int? @map("max_notifications_per_month")
  maxClasses           Int? @map("max_classes")    // class templates per gym
  maxStorageGb         Int? @map("max_storage_gb")

  // ── Feature flags ─────────────────────────────────────────
  attendanceTracking   Boolean @default(true)  @map("attendance_tracking")
  workoutPlans         Boolean @default(true)  @map("workout_plans")
  dietPlans            Boolean @default(false) @map("diet_plans")
  classScheduling      Boolean @default(false) @map("class_scheduling")
  reportsAnalytics     Boolean @default(false) @map("reports_analytics")
  onlinePayments       Boolean @default(false) @map("online_payments")
  balanceSheet         Boolean @default(false) @map("balance_sheet")
  supplementManagement Boolean @default(false) @map("supplement_management")
  customBranding       Boolean @default(false) @map("custom_branding")
  whatsappIntegration  Boolean @default(false) @map("whatsapp_integration")
  apiAccess            Boolean @default(false) @map("api_access")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  subscriptions SaasSubscription[]

  @@map("saas_plans")
}

// ────────────────────────────────────────────────────────────
// 6. SAAS SUBSCRIPTIONS  (gym owner's active plan with you)
// ────────────────────────────────────────────────────────────

model SaasSubscription {
  id                 String                 @id @default(uuid())
  profileId          String                 @map("profile_id")
  saasPlanId         String                 @map("saas_plan_id")
  status             SaasSubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime               @map("current_period_start")
  currentPeriodEnd   DateTime?              @map("current_period_end") // null for LIFETIME
  trialEndsAt        DateTime?              @map("trial_ends_at")
  cancelledAt        DateTime?              @map("cancelled_at")
  razorpaySubId      String?                @map("razorpay_sub_id")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  profile  Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  saasPlan SaasPlan      @relation(fields: [saasPlanId], references: [id])
  payments SaasPayment[]

  @@index([profileId])
  @@map("saas_subscriptions")
}

// ────────────────────────────────────────────────────────────
// 7. SAAS PAYMENTS  (what gym owners pay you)
// ────────────────────────────────────────────────────────────

model SaasPayment {
  id                String            @id @default(uuid())
  profileId         String            @map("profile_id")
  subscriptionId    String?           @map("subscription_id")
  amount            Decimal           @db.Decimal(10, 2)
  discountAmount    Decimal           @default(0) @map("discount_amount") @db.Decimal(10, 2) // wallet credits used
  finalAmount       Decimal           @map("final_amount") @db.Decimal(10, 2)               // amount - discount
  currency          String            @default("INR") @db.Char(3)
  status            SaasPaymentStatus @default(PENDING)
  razorpayPaymentId String?           @map("razorpay_payment_id")
  razorpayOrderId   String?           @map("razorpay_order_id")
  invoiceUrl        String?           @map("invoice_url")
  paidAt            DateTime?         @map("paid_at")
  createdAt         DateTime          @default(now()) @map("created_at")

  profile      Profile           @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subscription SaasSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([profileId])
  @@map("saas_payments")
}

// ════════════════════════════════════════════════════════════
// REFERRAL & WALLET
// ════════════════════════════════════════════════════════════

// ────────────────────────────────────────────────────────────
// 8. REFERRAL CODES  (one permanent code per profile)
// ────────────────────────────────────────────────────────────

model ReferralCode {
  id        String   @id @default(uuid())
  profileId String   @unique @map("profile_id")
  code      String   @unique   // e.g. "ROHIT2024" — shareable link/code
  createdAt DateTime @default(now()) @map("created_at")

  profile   Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  referrals Referral[]

  @@map("referral_codes")
}

// ────────────────────────────────────────────────────────────
// 9. REFERRALS
//
// Full lifecycle:
//  1. Owner A shares their code
//  2. Owner B registers using code    → status = PENDING
//  3. Owner B pays for any SaaS plan  → status = CONVERTED
//     → WalletTransaction CREDIT created for Owner A
//  4. If no purchase within expiresAt → status = EXPIRED (cron)
// ────────────────────────────────────────────────────────────

model Referral {
  id               String         @id @default(uuid())
  referralCodeId   String         @map("referral_code_id")
  referrerId       String         @map("referrer_id")
  referredId       String         @unique @map("referred_id") // one referral per person
  status           ReferralStatus @default(PENDING)
  rewardAmount     Decimal?       @map("reward_amount") @db.Decimal(10, 2)
  rewardCreditedAt DateTime?      @map("reward_credited_at")
  triggerPaymentId String?        @map("trigger_payment_id") // saas_payment.id that triggered conversion
  expiresAt        DateTime?      @map("expires_at")         // e.g. 30 days after signup
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  referralCode ReferralCode @relation(fields: [referralCodeId], references: [id])
  referrer     Profile      @relation("ReferrerProfile", fields: [referrerId], references: [id], onDelete: Cascade)
  referred     Profile      @relation("ReferredProfile", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@map("referrals")
}

// ────────────────────────────────────────────────────────────
// 10. WALLET  (one per profile)
// ────────────────────────────────────────────────────────────

model Wallet {
  id        String   @id @default(uuid())
  profileId String   @unique @map("profile_id")
  balance   Decimal  @default(0) @db.Decimal(10, 2) // always kept in sync with transactions
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile      Profile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

// ────────────────────────────────────────────────────────────
// 11. WALLET TRANSACTIONS  (immutable ledger — never delete rows)
//
// balance on Wallet = running total, kept updated after each txn.
// This table is the source of truth for auditing.
// ────────────────────────────────────────────────────────────

model WalletTransaction {
  id           String                @id @default(uuid())
  walletId     String                @map("wallet_id")
  type         WalletTransactionType
  amount       Decimal               @db.Decimal(10, 2) // always positive
  balanceAfter Decimal               @map("balance_after") @db.Decimal(10, 2) // snapshot
  description  String?               // e.g. "Referral reward — ROHIT2024 converted"
  referenceId  String?               @map("reference_id") // referral.id or payment.id
  gymId        String?               @map("gym_id")       // gym where credit was used
  expiresAt    DateTime?             @map("expires_at")   // 90-day expiry for CREDIT_ types
  createdAt    DateTime              @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([expiresAt])
  @@map("wallet_transactions")
}

// ════════════════════════════════════════════════════════════
// GYM OPERATIONS  (owner manages their gym)
// ════════════════════════════════════════════════════════════

// ────────────────────────────────────────────────────────────
// 12. MEMBERSHIP PLANS  (gym owner → their members, NOT SaaS)
// ────────────────────────────────────────────────────────────

model MembershipPlan {
  id             String   @id @default(uuid())
  gymId          String   @map("gym_id")
  name           String
  description    String?
  durationMonths Int      @map("duration_months")
  price          Decimal  @db.Decimal(10, 2)
  features       String[] @default([])
  maxClasses     Int?     @map("max_classes")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  gym      Gym         @relation(fields: [gymId], references: [id], onDelete: Cascade)
  members  GymMember[]
  payments Payment[]

  @@index([gymId])
  @@map("membership_plans")
}

// ────────────────────────────────────────────────────────────
// 13. GYM TRAINERS
// ────────────────────────────────────────────────────────────

model GymTrainer {
  id              String   @id @default(uuid())
  gymId           String   @map("gym_id")
  profileId       String   @unique @map("profile_id")
  specializations String[] @default([])
  certifications  String[] @default([])
  bio             String?
  experienceYears Int      @default(0) @map("experience_years")
  rating          Decimal  @default(0.00) @db.Decimal(3, 2)
  totalReviews    Int      @default(0) @map("total_reviews")
  isAvailable     Boolean  @default(true) @map("is_available")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  gym             Gym                   @relation(fields: [gymId], references: [id], onDelete: Cascade)
  profile         Profile               @relation(fields: [profileId], references: [id], onDelete: Cascade)
  availability    TrainerAvailability[]
  assignedMembers GymMember[]           @relation("AssignedTrainer")
  classes         Class[]
  classSessions   ClassSession[]
  reviews         TrainerReview[]

  @@unique([gymId, profileId])
  @@index([gymId])
  @@map("gym_trainers")
}

// ────────────────────────────────────────────────────────────
// 14. TRAINER AVAILABILITY
// ────────────────────────────────────────────────────────────

model TrainerAvailability {
  id           String    @id @default(uuid())
  gymTrainerId String    @map("gym_trainer_id")
  dayOfWeek    DayOfWeek @map("day_of_week")
  startTime    String    @map("start_time")
  endTime      String    @map("end_time")

  trainer GymTrainer @relation(fields: [gymTrainerId], references: [id], onDelete: Cascade)

  @@unique([gymTrainerId, dayOfWeek, startTime])
  @@map("trainer_availability")
}

// ────────────────────────────────────────────────────────────
// 15. GYM MEMBERS
// ────────────────────────────────────────────────────────────

model GymMember {
  id                    String       @id @default(uuid())
  gymId                 String       @map("gym_id")
  profileId             String       @map("profile_id")
  membershipPlanId      String?      @map("membership_plan_id")
  assignedTrainerId     String?      @map("assigned_trainer_id")
  membershipType        String?      @map("membership_type")
  status                MemberStatus @default(ACTIVE)
  registrationId        String?      @unique @map("registration_id")
  startDate             DateTime     @map("start_date") @db.Date
  endDate               DateTime?    @map("end_date") @db.Date
  heightCm              Decimal?     @map("height_cm") @db.Decimal(5, 2)
  weightKg              Decimal?     @map("weight_kg") @db.Decimal(5, 2)
  medicalNotes          String?      @map("medical_notes")
  emergencyContactName  String?      @map("emergency_contact_name")
  emergencyContactPhone String?      @map("emergency_contact_phone")
  currentStreak         Int          @default(0) @map("current_streak")
  longestStreak         Int          @default(0) @map("longest_streak")
  lastCheckinDate       DateTime?    @map("last_checkin_date") @db.Date
  totalCheckins         Int          @default(0) @map("total_checkins")
  workoutStartTime      String?      @map("workout_start_time")       // e.g. "05:00"
  workoutEndTime        String?      @map("workout_end_time")         // e.g. "06:00"
  isActive              Boolean      @default(true) @map("is_active")
  // History tracking
  expiredAt             DateTime?    @map("expired_at")               // set when membership is confirmed expired — drives plan visibility
  gymNameSnapshot       String?      @map("gym_name_snapshot")        // denormalised gym name at time of joining — safe to show even if gym is deleted
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  gym             Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)
  profile         Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  membershipPlan  MembershipPlan? @relation(fields: [membershipPlanId], references: [id], onDelete: SetNull)
  assignedTrainer GymTrainer?     @relation("AssignedTrainer", fields: [assignedTrainerId], references: [id], onDelete: SetNull)
  attendance      Attendance[]
  payments        Payment[]
  classBookings       ClassBooking[]
  workoutPlans        WorkoutPlan[]   @relation("WorkoutPlanMember")
  supplementSales     SupplementSale[]
  dietPlans       DietPlan[]      @relation("DietPlanMember")
  workoutLogs     WorkoutLog[]
  bodyMetrics     BodyMetric[]
  trainerReviews       TrainerReview[]
  attendanceMilestones AttendanceMilestone[]
  lockerAssignments    LockerAssignment[]

  @@unique([gymId, profileId])
  @@index([gymId])
  @@index([profileId])
  @@index([assignedTrainerId])
  @@index([createdAt])
  @@index([endDate])
  @@map("gym_members")
}

// ────────────────────────────────────────────────────────────
// 16. ATTENDANCE
// ────────────────────────────────────────────────────────────

model Attendance {
  id           String           @id @default(uuid())
  gymId        String           @map("gym_id")
  memberId     String           @map("member_id")
  checkInTime  DateTime         @default(now()) @map("check_in_time")
  checkOutTime DateTime?        @map("check_out_time")
  method       AttendanceMethod @default(MANUAL)

  gym    Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  member GymMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([gymId])
  @@index([memberId])
  @@index([checkInTime])
  @@map("attendance")
}

// ────────────────────────────────────────────────────────────
// 17. PAYMENTS  (gym member → gym, NOT SaaS)
// ────────────────────────────────────────────────────────────

model Payment {
  id                String        @id @default(uuid())
  gymId             String        @map("gym_id")
  memberId          String        @map("member_id")
  membershipPlanId  String?       @map("membership_plan_id")
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("INR") @db.Char(3)
  paymentMethod     String?       @map("payment_method")
  status            PaymentStatus @default(PENDING)
  razorpayPaymentId String?       @map("razorpay_payment_id")
  razorpayOrderId   String?       @map("razorpay_order_id")
  invoiceUrl        String?       @map("invoice_url")
  paymentDate       DateTime?     @map("payment_date")
  planNameSnapshot  String?       @map("plan_name_snapshot")  // denormalised plan name — safe to show even if plan is deleted
  notes             String?                                    // optional payment note from owner
  createdAt         DateTime      @default(now()) @map("created_at")

  gym            Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)
  member         GymMember       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  membershipPlan MembershipPlan? @relation(fields: [membershipPlanId], references: [id], onDelete: SetNull)

  @@index([gymId])
  @@index([memberId])
  @@index([paymentDate])
  @@map("payments")
}

// ────────────────────────────────────────────────────────────
// 18. CLASS CATEGORIES
// ────────────────────────────────────────────────────────────

model ClassCategory {
  id          String  @id @default(uuid())
  gymId       String  @map("gym_id")
  name        String
  description String?
  colorHex    String  @default("#6366F1") @map("color_hex") @db.Char(7)

  gym     Gym     @relation(fields: [gymId], references: [id], onDelete: Cascade)
  classes Class[]

  @@map("class_categories")
}

// ────────────────────────────────────────────────────────────
// 19. CLASSES
// ────────────────────────────────────────────────────────────

model Class {
  id             String          @id @default(uuid())
  gymId          String          @map("gym_id")
  gymTrainerId   String          @map("gym_trainer_id")
  categoryId     String?         @map("category_id")
  title          String
  description    String?
  difficulty     DifficultyLevel @default(BEGINNER)
  durationMin    Int             @map("duration_min")
  maxCapacity    Int             @default(20) @map("max_capacity")
  location       String?
  meetingUrl     String?         @map("meeting_url")
  isRecurring    Boolean         @default(false) @map("is_recurring")
  recurrenceDays DayOfWeek[]     @default([]) @map("recurrence_days")
  recurrenceTime String?         @map("recurrence_time")
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  gym      Gym            @relation(fields: [gymId], references: [id], onDelete: Cascade)
  trainer  GymTrainer     @relation(fields: [gymTrainerId], references: [id], onDelete: Cascade)
  category ClassCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  sessions ClassSession[]

  @@index([gymId])
  @@index([gymTrainerId])
  @@map("classes")
}

// ────────────────────────────────────────────────────────────
// 20. CLASS SESSIONS
// ────────────────────────────────────────────────────────────

model ClassSession {
  id              String      @id @default(uuid())
  classId         String      @map("class_id")
  gymTrainerId    String      @map("gym_trainer_id")
  startsAt        DateTime    @map("starts_at")
  endsAt          DateTime    @map("ends_at")
  status          ClassStatus @default(SCHEDULED)
  currentBookings Int         @default(0) @map("current_bookings")
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")

  class    Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  trainer  GymTrainer     @relation(fields: [gymTrainerId], references: [id], onDelete: Cascade)
  bookings ClassBooking[]

  @@index([classId])
  @@index([startsAt])
  @@map("class_sessions")
}

// ────────────────────────────────────────────────────────────
// 21. CLASS BOOKINGS
// ────────────────────────────────────────────────────────────

model ClassBooking {
  id          String        @id @default(uuid())
  sessionId   String        @map("session_id")
  memberId    String        @map("member_id")
  status      BookingStatus @default(BOOKED)
  bookedAt    DateTime      @default(now()) @map("booked_at")
  cancelledAt DateTime?     @map("cancelled_at")

  session ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  member  GymMember    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([sessionId, memberId])
  @@index([sessionId])
  @@index([memberId])
  @@map("class_bookings")
}

// ────────────────────────────────────────────────────────────
// 22. WORKOUT PLANS
// ────────────────────────────────────────────────────────────

model WorkoutPlan {
  id                 String          @id @default(uuid())
  gymId              String          @map("gym_id")
  createdBy          String          @map("created_by")
  assignedToMemberId String?         @map("assigned_to_member_id")
  title              String?
  description        String?
  goal               String?
  difficulty         DifficultyLevel @default(BEGINNER)
  isGlobal           Boolean         @default(false) @map("is_global")
  isTemplate         Boolean         @default(false) @map("is_template")
  durationWeeks      Int             @default(4) @map("duration_weeks")
  weekStartDate      DateTime?       @map("week_start_date") @db.Date
  planData           Json            @default("{}") @map("plan_data")
  isActive           Boolean         @default(true) @map("is_active")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  gym            Gym          @relation(fields: [gymId], references: [id], onDelete: Cascade)
  creator        Profile      @relation("WorkoutPlanCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  assignedMember GymMember?   @relation("WorkoutPlanMember", fields: [assignedToMemberId], references: [id], onDelete: Cascade)
  workoutLogs    WorkoutLog[]

  @@index([gymId])
  @@index([assignedToMemberId])
  @@map("workout_plans")
}

// ────────────────────────────────────────────────────────────
// 23. WORKOUT LOGS
// ────────────────────────────────────────────────────────────

model WorkoutLog {
  id                  String   @id @default(uuid())
  memberId            String   @map("member_id")
  workoutPlanId       String?  @map("workout_plan_id")
  weekNumber          Int?     @map("week_number")
  dayNumber           Int?     @map("day_number")
  durationMin         Int?     @map("duration_min")
  perceivedDifficulty Int?     @map("perceived_difficulty")
  notes               String?
  loggedAt            DateTime @default(now()) @map("logged_at")

  member      GymMember       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  workoutPlan WorkoutPlan?    @relation(fields: [workoutPlanId], references: [id], onDelete: SetNull)
  sets        WorkoutLogSet[]

  @@index([memberId])
  @@map("workout_logs")
}

model WorkoutLogSet {
  id           String   @id @default(uuid())
  logId        String   @map("log_id")
  exerciseName String   @map("exercise_name")
  setNumber    Int      @map("set_number")
  repsDone     Int?     @map("reps_done")
  weightKg     Decimal? @map("weight_kg") @db.Decimal(6, 2)
  durationSec  Int?     @map("duration_sec")
  completed    Boolean  @default(true)

  log WorkoutLog @relation(fields: [logId], references: [id], onDelete: Cascade)

  @@map("workout_log_sets")
}

// ────────────────────────────────────────────────────────────
// 24. DIET PLANS
// ────────────────────────────────────────────────────────────

model DietPlan {
  id                 String    @id @default(uuid())
  gymId              String    @map("gym_id")
  createdBy          String    @map("created_by")
  assignedToMemberId String?   @map("assigned_to_member_id")
  title              String?
  description        String?
  goal               String?
  caloriesTarget     Int?      @map("calories_target")
  proteinG           Decimal?  @map("protein_g") @db.Decimal(6, 2)
  carbsG             Decimal?  @map("carbs_g") @db.Decimal(6, 2)
  fatG               Decimal?  @map("fat_g") @db.Decimal(6, 2)
  isGlobal           Boolean   @default(false) @map("is_global")
  isTemplate         Boolean   @default(false) @map("is_template")
  durationWeeks      Int       @default(4) @map("duration_weeks")
  weekStartDate      DateTime? @map("week_start_date") @db.Date
  planData           Json      @default("{}") @map("plan_data")
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  gym            Gym        @relation(fields: [gymId], references: [id], onDelete: Cascade)
  creator        Profile    @relation("DietPlanCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  assignedMember GymMember? @relation("DietPlanMember", fields: [assignedToMemberId], references: [id], onDelete: Cascade)

  @@index([gymId])
  @@index([assignedToMemberId])
  @@map("diet_plans")
}

// ────────────────────────────────────────────────────────────
// 25. BODY METRICS
// ────────────────────────────────────────────────────────────

model BodyMetric {
  id           String   @id @default(uuid())
  memberId     String   @map("member_id")
  recordedAt   DateTime @default(now()) @map("recorded_at") @db.Date
  weightKg     Decimal? @map("weight_kg") @db.Decimal(5, 2)
  bodyFatPct   Decimal? @map("body_fat_pct") @db.Decimal(4, 2)
  muscleMassKg Decimal? @map("muscle_mass_kg") @db.Decimal(5, 2)
  bmi          Decimal? @db.Decimal(4, 2)
  chestCm      Decimal? @map("chest_cm") @db.Decimal(5, 2)
  waistCm      Decimal? @map("waist_cm") @db.Decimal(5, 2)
  hipsCm       Decimal? @map("hips_cm") @db.Decimal(5, 2)
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  member GymMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("body_metrics")
}

// ────────────────────────────────────────────────────────────
// 26. TRAINER REVIEWS
// ────────────────────────────────────────────────────────────

model TrainerReview {
  id           String   @id @default(uuid())
  gymTrainerId String   @map("gym_trainer_id")
  memberId     String   @map("member_id")
  rating       Int
  comment      String?
  createdAt    DateTime @default(now()) @map("created_at")

  trainer GymTrainer @relation(fields: [gymTrainerId], references: [id], onDelete: Cascade)
  member  GymMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([gymTrainerId, memberId])
  @@map("trainer_reviews")
}

// ────────────────────────────────────────────────────────────
// 27. ANNOUNCEMENTS
// ────────────────────────────────────────────────────────────

model Announcement {
  id          String      @id @default(uuid())
  gymId       String      @map("gym_id")
  authorId    String      @map("author_id")
  title       String
  body        String
  targetRole  TargetRole? @map("target_role")
  publishedAt DateTime?   @map("published_at")
  expiresAt   DateTime?   @map("expires_at")
  createdAt   DateTime    @default(now()) @map("created_at")

  gym    Gym     @relation(fields: [gymId], references: [id], onDelete: Cascade)
  author Profile @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("announcements")
}

// ────────────────────────────────────────────────────────────
// 28. NOTIFICATIONS
// ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  gymId     String?          @map("gym_id")
  profileId String           @map("profile_id")
  title     String
  message   String?
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json             @default("{}")
  createdAt DateTime         @default(now()) @map("created_at")

  gym     Gym?    @relation(fields: [gymId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, isRead])
  @@map("notifications")
}

// ────────────────────────────────────────────────────────────
// SUPPLEMENTS  (inventory + sales tracking per gym)
// ────────────────────────────────────────────────────────────

model Supplement {
  id          String   @id @default(uuid())
  gymId       String   @map("gym_id")
  name        String
  brand       String?
  category    String?  // e.g. "Protein", "Creatine", "Vitamins"
  description String?
  unitSize    String?  @map("unit_size")   // e.g. "1kg", "60 caps"
  price       Decimal  @db.Decimal(10, 2)  // selling price
  costPrice   Decimal? @map("cost_price") @db.Decimal(10, 2) // purchase cost
  stockQty    Int      @default(0) @map("stock_qty")
  lowStockAt  Int      @default(5)  @map("low_stock_at") // alert threshold
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  gym   Gym                @relation(fields: [gymId], references: [id], onDelete: Cascade)
  sales SupplementSale[]

  @@index([gymId])
  @@map("supplements")
}

model SupplementSale {
  id             String   @id @default(uuid())
  supplementId   String   @map("supplement_id")
  gymId          String   @map("gym_id")
  memberId       String?  @map("member_id")  // null if sold to walk-in
  memberName     String?  @map("member_name") // snapshot — useful if walk-in
  qty            Int
  unitPrice      Decimal  @map("unit_price")  @db.Decimal(10, 2)
  totalAmount    Decimal  @map("total_amount") @db.Decimal(10, 2)
  paymentMethod  String   @default("CASH") @map("payment_method")
  notes          String?
  soldAt         DateTime @default(now()) @map("sold_at")
  createdAt      DateTime @default(now()) @map("created_at")

  supplement Supplement @relation(fields: [supplementId], references: [id], onDelete: Cascade)
  gym        Gym        @relation(fields: [gymId], references: [id], onDelete: Cascade)
  member     GymMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([gymId])
  @@index([supplementId])
  @@index([soldAt])
  @@map("supplement_sales")
}


// ────────────────────────────────────────────────────────────
// ATTENDANCE MILESTONES  (streak badges & poster generation)
// ────────────────────────────────────────────────────────────

model AttendanceMilestone {
  id          String   @id @default(uuid())
  memberId    String   @map("member_id")
  gymId       String   @map("gym_id")
  milestone   Int      // 30, 100, 365 etc.
  achievedAt  DateTime @default(now()) @map("achieved_at")
  posterUrl   String?  @map("poster_url")   // Cloudinary URL if generated
  notified    Boolean  @default(false)

  member GymMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  gym    Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([memberId, milestone])
  @@map("attendance_milestones")
}

// ────────────────────────────────────────────────────────────
// PUSH SUBSCRIPTIONS  (Web Push / PWA notifications)
// ────────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  endpoint  String   @unique
  p256dh    String   @map("p256dh")
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("push_subscriptions")
}

// ────────────────────────────────────────────────────────────
// PLAN TEMPLATES  (reusable workout/diet plan templates)
// ────────────────────────────────────────────────────────────

model PlanTemplate {
  id           String   @id @default(uuid())
  ownerGymId   String?  @map("owner_gym_id")    // null = global/system template
  createdById  String   @map("created_by_id")
  type         String   // "WORKOUT" | "DIET"
  title        String
  description  String?
  goal         String?
  difficulty   String?  // BEGINNER | INTERMEDIATE | ADVANCED (workout)
  planData     Json     @map("plan_data")
  isGlobal     Boolean  @default(false) @map("is_global") // visible to all gyms
  usageCount   Int      @default(0) @map("usage_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  createdBy Profile @relation(fields: [createdById], references: [id], onDelete: Cascade)
  gym       Gym?    @relation(fields: [ownerGymId], references: [id], onDelete: SetNull)

  @@index([type, isGlobal])
  @@index([ownerGymId])
  @@map("plan_templates")
}

// ────────────────────────────────────────────────────────────
// GYM EXPENSES  (track operating costs per gym)
// ────────────────────────────────────────────────────────────

enum ExpenseCategory {
  ELECTRICITY
  WATER
  RENT
  EQUIPMENT_PURCHASE
  EQUIPMENT_MAINTENANCE
  STAFF_SALARY
  MARKETING
  CLEANING
  INSURANCE
  INTERNET
  SOFTWARE
  MISCELLANEOUS
}

model GymExpense {
  id          String          @id @default(uuid())
  gymId       String          @map("gym_id")
  addedById   String          @map("added_by_id")   // owner profileId
  title       String                                  // e.g. "October Electricity Bill"
  amount      Decimal         @db.Decimal(10, 2)
  category    ExpenseCategory @default(MISCELLANEOUS)
  description String?                                 // optional notes
  expenseDate DateTime        @map("expense_date") @db.Date
  receiptUrl  String?         @map("receipt_url")   // optional receipt image
  createdAt   DateTime        @default(now())        @map("created_at")
  updatedAt   DateTime        @updatedAt             @map("updated_at")

  gym     Gym     @relation(fields: [gymId], references: [id], onDelete: Cascade)
  addedBy Profile @relation("ExpenseAdder", fields: [addedById], references: [id], onDelete: Cascade)

  @@index([gymId])
  @@index([expenseDate])
  @@map("gym_expenses")
}

// ────────────────────────────────────────────────────────────
// LOCKERS  (locker inventory + assignment per gym)
// ────────────────────────────────────────────────────────────

enum LockerStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RESERVED
}

model Locker {
  id          String       @id @default(uuid())
  gymId       String       @map("gym_id")
  lockerNumber String      @map("locker_number")   // e.g. "A-01", "101"
  floor       String?                               // optional floor/zone
  size        String?                               // SMALL | MEDIUM | LARGE
  status      LockerStatus @default(AVAILABLE)
  monthlyFee  Decimal?     @map("monthly_fee") @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  gym         Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  assignments LockerAssignment[]

  @@unique([gymId, lockerNumber])
  @@index([gymId])
  @@map("lockers")
}

model LockerAssignment {
  id          String    @id @default(uuid())
  lockerId    String    @map("locker_id")
  memberId    String    @map("member_id")       // GymMember.id
  gymId       String    @map("gym_id")
  assignedAt  DateTime  @default(now()) @map("assigned_at")
  expiresAt   DateTime? @map("expires_at")      // optional — null means no expiry
  isActive    Boolean   @default(true)           @map("is_active")
  feeCollected Boolean  @default(false)          @map("fee_collected")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  locker Locker    @relation(fields: [lockerId], references: [id], onDelete: Cascade)
  member GymMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  gym    Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([lockerId])
  @@index([memberId])
  @@index([gymId])
  @@map("locker_assignments")
}

model EmailOtp {
  id        String   @id @default(uuid())
  email     String
  otpHash   String   @map("otp_hash")
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("email_otps")
}

// ────────────────────────────────────────────────────────────
// INVITE TOKENS  (SMS-based onboarding for owner-added members/trainers)
// ────────────────────────────────────────────────────────────

model InviteToken {
  id        String    @id @default(uuid())
  profileId String    @map("profile_id")
  gymId     String?   @map("gym_id")         // which gym sent the invite
  gymName   String?   @map("gym_name")       // snapshot — survives gym deletion
  token     String    @unique
  expiresAt DateTime  @map("expires_at")     // 30 days
  usedAt    DateTime? @map("used_at")        // null = not yet used
  createdAt DateTime  @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([token])
  @@map("invite_tokens")
}
